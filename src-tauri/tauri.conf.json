{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CleanSlate QA",
  "version": "2.0.0",
  "identifier": "com.cleanslate.qa",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CleanSlate QA v2.0",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "cleanup-commands",
          "cmd": "*",
          "args": true
        }
      ]
    },
    "log": {
      "tagPattern": "[a-zA-Z0-9_.\\-]+"
    }
  }
}
